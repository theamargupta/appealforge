# ─── Site ──────────────────────────────────────────────────────────────────
# Canonical base URL (used for sitemap, canonical tags, OpenGraph, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://appealforge.vercel.app

# ─── AI generation (optional) ────────────────────────────────────────────────
# When ANTHROPIC_API_KEY is set, appeals are generated by Claude. When unset,
# the app falls back to a high-quality deterministic template so it always works.
ANTHROPIC_API_KEY=
# Tier → model mapping (server-side only — never exposed to the client).
# "Standard" = fast/cheap, "Enhanced" = more detailed. Defaults shown.
ANTHROPIC_MODEL_STANDARD=claude-haiku-4-5
ANTHROPIC_MODEL_ENHANCED=claude-sonnet-4-6

# ─── Lead capture (Supabase) ─────────────────────────────────────────────────
# Publishable (anon) key is safe to expose. Leads insert into `appealforge_leads`
# (write-only RLS: anon can INSERT, no SELECT).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Analytics ───────────────────────────────────────────────────────────────
# GA4 measurement ID.
NEXT_PUBLIC_GA_ID=
# Google Search Console HTML-tag verification token.
NEXT_PUBLIC_GSC_VERIFICATION=

# ─── Monetization ────────────────────────────────────────────────────────────
# Google AdSense publisher ID (ca-pub-...). Ad slots show a placeholder until set.
NEXT_PUBLIC_ADSENSE_CLIENT=
